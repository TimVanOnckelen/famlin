.expo-shared/
*.ipa
*.apk
*.aab
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
mobile/secrets/

# Prisma
prisma/migrations/*_init/

# Docker volumes
famlin-db-data/

