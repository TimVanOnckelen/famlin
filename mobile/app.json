{
  "expo": {
    "name": "Famlin",
    "slug": "famlin",
    "version": "0.3.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "be.xeweb.famlin",
      "buildNumber": "0.3.2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "be.xeweb.famlin",
      "versionCode": 570000200,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006e94"
      },
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "42c3e9a8-50e3-4f19-a670-e9cb2766f3c9"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#006e94"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Famlin to save photos to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
