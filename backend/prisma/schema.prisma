generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  avatarUrl         String?
  passwordHash      String?
  createdAt         DateTime       @default(now())
  isAdmin           Boolean        @default(false)
  // Bumped on password change/reset so previously issued JWTs (which embed
  // the version they were signed with) stop being accepted immediately,
  // instead of remaining valid for the rest of their 30-day lifetime.
  tokenVersion      Int            @default(0)
  emailOnNewPost    Boolean        @default(true)
  emailOnNewComment Boolean        @default(true)
  emailOnNewLike    Boolean        @default(true)
  pushOnNewPost     Boolean        @default(true)
  pushOnNewComment  Boolean        @default(true)
  pushOnNewLike     Boolean        @default(true)
  pushTokens        PushToken[]
  groupMemberships  GroupMember[]
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  favorites         Favorite[]
  notifications     Notification[]
  createdInvites    Invite[]       @relation("InviteCreatedBy")
  usedInvites       Invite[]       @relation("InviteUsedBy")
  apiTokens         ApiToken[]
  mediaPersonLinks  MediaPersonLink[]
  postInteractions  PostInteraction[]
  triggeredPushLogs PushDeliveryLog[]
  pushOnChitchat    Boolean           @default(true)
  chatMessages      ChatMessage[]
  chatReads         ChatRead[]
}

// A personal access token a member creates to call the API from their own
// scripts and integrations (Authorization: Bearer famlin_pat_...). Only a
// SHA-256 hash of the secret is stored — the plaintext is returned once at
// creation. It authenticates as the owning user, so the group-membership
// authorization rule applies to it unchanged; revocation is deleting the row
// (deleting the user cascades). Deliberately independent of User.tokenVersion:
// a password reset signs out sessions but keeps integrations running.
model ApiToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  tokenHash    String    @unique
  // First characters of the secret, kept so the owner can tell tokens apart
  // in the list without storing anything that's usable as a credential.
  tokenPreview String
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Post types members may create in this group, by PostTypeHandler id
  // (services/postTypes/registry.ts). Empty = all registered types allowed
  // (same convention as the allowedEmails setting) — member-facing responses
  // resolve it through resolveAllowedPostTypes() so clients never see an
  // empty list; only admin responses expose the raw stored array. Enforced
  // at creation time only: existing posts of a later-disallowed type stay
  // visible.
  allowedPostTypes String[] @default([])
  // Whether this group's single central chat ("chitchat") is turned on —
  // off by default, an admin opt-in per group (see routes/admin.ts group
  // create/update). Member-facing chat routes 403 with
  // errors.chitchatDisabled while this is false.
  chitchatEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  members     GroupMember[]
  posts       Post[]
  invites     Invite[]
  mediaAlbumLinks MediaAlbumLink[]
  chatMessages    ChatMessage[]
  chatReads       ChatRead[]
}

model GroupMember {
  id       String  @id @default(cuid())
  groupId  String
  group    Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model Post {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  content         String?
  // Open string discriminator (was the closed PostType enum: UPDATE /
  // MILESTONE) so new post types (POLL, and whatever comes after it) can be
  // added without a migration — see services/postTypes/registry.ts, the
  // PostTypeHandler registry that owns per-type validation. Never renamed
  // once a deployment has posts of that type.
  type            String   @default("UPDATE")
  // Handler-owned, type-specific config (e.g. a poll's options/closesAt) —
  // null for UPDATE/MILESTONE. Validated/transformed by the type's
  // PostTypeHandler at create time, immutable afterward. `content` stays the
  // universal human-readable field (a poll's question), so search,
  // notification previews, and old clients keep working unmodified.
  typeData        Json?
  milestoneTag    String?
  uploadedAssetUrls String[]
  createdAt       DateTime @default(now())
  editedAt        DateTime?
  latitude        Float?
  longitude       Float?
  locationName    String?
  comments        Comment[]
  likes           Like[]
  favorites       Favorite[]
  notifications   Notification[]
  // System chat messages (kind: SYSTEM_MILESTONE) that deep-link back to this
  // post — see ChatMessage.refPostId below.
  chatMessages    ChatMessage[]
  // Shared by every sibling row of one cross-post (see the "cross-posting"
  // feature: one Post row per target group, all created together with this
  // same id) — null for an ordinary single-group post. Never exposed in any
  // API response (see shapePost in services/posts.ts): a non-author must
  // never be able to tell a post was cross-posted.
  crossPostId     String?
  // Per-user state for this post's type (poll votes today; RSVPs, etc.
  // later) — a generic, handler-owned table rather than one column per
  // feature. Never included in postInclude (routes/posts.ts) or serialized
  // directly; each PostTypeHandler owns reading/writing its own `key`
  // namespace (see services/postTypes/poll.ts).
  interactions    PostInteraction[]
  pushDeliveryLogs PushDeliveryLog[]

  @@index([groupId, createdAt])
  @@index([crossPostId])
}

// Generic per-user state against a post, owned by that post's
// PostTypeHandler (see services/postTypes/) rather than a dedicated table per
// feature — a poll vote today (`key: "vote"`, `value: { optionId }`), future
// RSVPs/acknowledgements reusing the same shape. `key` namespaces different
// interaction kinds a single post type might have; the unique constraint is
// one row per (post, user, key) so "vote" is naturally one-per-user, with the
// handler switching the existing row's value instead of adding a second one
// (mirrors Like's one-reaction-per-user-per-post model).
model PostInteraction {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())

  @@unique([postId, userId, key])
  @@index([postId, key])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Set when the comment is pinned to one photo/video in the post's
  // uploadedAssetUrls rather than the post as a whole (null = post-level).
  assetUrl  String?
  // A photo/video the commenter uploaded as part of this comment itself
  // (an /uploads/ path, like Post.uploadedAssetUrls) — distinct from
  // assetUrl, which instead points at an existing asset on the post.
  attachmentUrl String?
  content   String
  // Handler-owned, type-specific payload for a comment created BY a post-type
  // handler rather than the plain comments route — e.g. a TRIP post's
  // check-ins (services/postTypes/trip.ts): {kind: 'trip_checkin', place,
  // photoUrls}. null for every ordinary comment. The public POST
  // /api/posts/:postId/comments route never accepts this from a client (see
  // createCommentBodySchema) — only a post-type handler writes it, so
  // metadata.kind is a trustworthy discriminator for "this comment is really
  // a type-specific interaction, not user-authored prose."
  metadata  Json?
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]

  @@index([postId, createdAt])
}

// A message in a group's single central chat ("chitchat"). USER messages are
// authored directly; SYSTEM_MILESTONE messages are auto-generated when a
// milestone post is created in a group with chitchatEnabled — authorId is the
// milestone post's author, refPostId links back to it so the client can
// deep-link. kind is an open string discriminator, same convention as
// Post.type — never rename a persisted value.
model ChatMessage {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind          String   @default("USER")
  content       String?
  attachmentUrl String?
  refPostId     String?
  refPost       Post?    @relation(fields: [refPostId], references: [id], onDelete: SetNull)
  replyToMessageId String?
  replyToMessage   ChatMessage?  @relation("ChatMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          ChatMessage[] @relation("ChatMessageReplies")
  createdAt     DateTime @default(now())
  editedAt      DateTime?

  @@index([groupId, createdAt])
  @@index([replyToMessageId])
}

// One row per (group, user) — the timestamp of that user's last chat read.
// Read-by / unread-count are computed from this rather than a per-message
// receipt table: a message is "read by" every member whose lastReadAt is
// >= that message's createdAt.
model ChatRead {
  id         String   @id @default(cuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([groupId, userId])
}

// Reacts to a post or a comment (exactly one of postId/commentId is set).
// Still named Like/one-row-per-user for history, but `type` now holds one of
// several emoji reactions rather than a plain boolean like.
model Like {
  id        String       @id @default(cuid())
  postId    String?
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@unique([commentId, userId])
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  CARE
}

// A post a user has bookmarked for their personal favorites overview.
model Favorite {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  relatedPostId String?
  post          Post?     @relation(fields: [relatedPostId], references: [id], onDelete: SetNull)
  message       String
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Delivery telemetry for one push-notification send attempt (one Expo API
// call) — covers both organic sends (post.created, comment.created, ...) and
// an admin's manual "resend push" for a post. Distinct from Notification
// (the in-app history a recipient sees, one row per recipient): this is one
// row per send() call, written by sendPush() in
// services/notificationChannels/push.ts.
model PushDeliveryLog {
  id                 String   @id @default(cuid())
  postId             String?
  post               Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  notifyType         String
  recipientCount     Int
  tokenCount         Int
  successCount       Int
  failureCount       Int
  // Set only when an admin triggered this via "resend push" — null for every
  // organic, event-triggered send.
  triggeredByAdminId String?
  triggeredByAdmin   User?    @relation(fields: [triggeredByAdminId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())

  @@index([postId, createdAt])
  @@index([createdAt])
}

// Links one external media album to a Famlin group, so group members can
// pick photos from it when composing a post. `provider` says which media
// source the album lives on ('immich', 'local', ... — see
// src/services/media/registry.ts) and `externalAlbumId` is that provider's
// album identifier (an Immich album uuid, a local folder name). The link is
// the entire authorization boundary for the /api/media and /api/immich asset
// proxies — plus the per-request isAssetInAlbum re-check.
model MediaAlbumLink {
  id              String   @id @default(cuid())
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  provider        String   @default("immich")
  externalAlbumId String
  // Cached label from the provider at link time, shown in the admin UI
  // without an extra round-trip; not kept in sync if renamed provider-side.
  albumName       String
  createdAt       DateTime @default(now())
  // Whether/how src/jobs/newAssets.ts surfaces newly-added assets on this
  // album: OFF (never), MANUAL (a notification), AUTO (a real Post).
  newAssetMode       NewAssetMode @default(OFF)
  // Last time the new-assets job scanned this link — null means it has never
  // run for this link, in which case the job only initializes the timestamp
  // (never notifies the album's entire pre-existing history).
  newAssetsCheckedAt DateTime?

  @@unique([groupId, provider, externalAlbumId])
  @@index([groupId])
}

enum NewAssetMode {
  OFF
  MANUAL
  AUTO
}

// Maps a provider's face/person identity (e.g. an Immich person) to a
// human-readable label and, optionally, the Famlin user it represents — lets
// members filter an album's assets down to just one person via
// GET /api/media/albums/:linkId/assets?personId=. Independent of any single
// MediaAlbumLink since the same provider-level person id can appear across
// several linked albums.
model MediaPersonLink {
  id               String   @id @default(cuid())
  provider         String
  externalPersonId String
  // Display name shown to family members — set by the admin at mapping time,
  // not synced from the provider afterwards.
  label            String
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@unique([provider, externalPersonId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// A single-use link an admin generates to let someone join a group without
// an existing account or an allowedEmails entry — the invite itself is the
// authorization.
model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email       String?
  createdById String?
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime?
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([groupId])
}
