generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  avatarUrl         String?
  passwordHash      String?
  createdAt         DateTime       @default(now())
  isAdmin           Boolean        @default(false)
  // Bumped on password change/reset so previously issued JWTs (which embed
  // the version they were signed with) stop being accepted immediately,
  // instead of remaining valid for the rest of their 30-day lifetime.
  tokenVersion      Int            @default(0)
  emailOnNewPost    Boolean        @default(true)
  emailOnNewComment Boolean        @default(true)
  emailOnNewLike    Boolean        @default(true)
  pushOnNewPost     Boolean        @default(true)
  pushOnNewComment  Boolean        @default(true)
  pushOnNewLike     Boolean        @default(true)
  pushTokens        PushToken[]
  groupMemberships  GroupMember[]
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  favorites         Favorite[]
  notifications     Notification[]
  createdInvites    Invite[]       @relation("InviteCreatedBy")
  usedInvites       Invite[]       @relation("InviteUsedBy")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  members     GroupMember[]
  posts       Post[]
  invites     Invite[]
  immichAlbumLinks ImmichAlbumLink[]
}

model GroupMember {
  id       String  @id @default(cuid())
  groupId  String
  group    Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model Post {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  content         String?
  type            PostType @default(UPDATE)
  milestoneTag    String?
  uploadedAssetUrls String[]
  createdAt       DateTime @default(now())
  editedAt        DateTime?
  latitude        Float?
  longitude       Float?
  locationName    String?
  comments        Comment[]
  likes           Like[]
  favorites       Favorite[]
  notifications   Notification[]

  @@index([groupId, createdAt])
}

enum PostType {
  UPDATE
  MILESTONE
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Set when the comment is pinned to one photo/video in the post's
  // uploadedAssetUrls rather than the post as a whole (null = post-level).
  assetUrl  String?
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]

  @@index([postId, createdAt])
}

// Reacts to a post or a comment (exactly one of postId/commentId is set).
// Still named Like/one-row-per-user for history, but `type` now holds one of
// several emoji reactions rather than a plain boolean like.
model Like {
  id        String       @id @default(cuid())
  postId    String?
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@unique([commentId, userId])
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  CARE
}

// A post a user has bookmarked for their personal favorites overview.
model Favorite {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  relatedPostId String?
  post          Post?     @relation(fields: [relatedPostId], references: [id], onDelete: SetNull)
  message       String
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Links one Immich album (identified by its Immich-side album id) to a
// Famlin group, so group members can pick photos from it when composing a
// post. An album can only be linked to one group at a time — that link is
// the entire authorization boundary for the /api/immich asset proxy.
model ImmichAlbumLink {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  immichAlbumId String
  // Cached label from Immich at link time, shown in the admin UI without an
  // extra round-trip; not kept in sync if renamed on the Immich side.
  albumName     String
  createdAt     DateTime @default(now())

  @@unique([groupId, immichAlbumId])
  @@index([groupId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// A single-use link an admin generates to let someone join a group without
// an existing account or an allowedEmails entry — the invite itself is the
// authorization.
model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email       String?
  createdById String?
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime?
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([groupId])
}
