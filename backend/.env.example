# Minimale opstart-configuratie. Alle overige instellingen worden via /admin beheerd.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://famlin:famlin@famlin-db:5432/famlin?schema=public
JWT_SECRET=change-this-to-a-secure-random-string-with-at-least-32-characters
# Only set to true behind a reverse proxy that sets (and overwrites) X-Forwarded-*.
TRUST_PROXY=false
