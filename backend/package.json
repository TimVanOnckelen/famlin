{
  "name": "famlin-backend",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "description": "Fastify backend for Famlin",
  "license": "MIT",
  "keywords": [
    "famlin",
    "fastify",
    "prisma",
    "postgres"
  ],
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && npm run build:admin",
    "build:admin": "cd admin && npm ci && npm run build",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:docker": "sh scripts/test-in-docker.sh",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.15.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^3.10.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "i18next": "^26.3.4",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.8",
    "@types/nodemailer": "^6.4.15",
    "eslint": "^9.39.0",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.15.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
