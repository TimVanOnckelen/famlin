# Backend (used by Docker Compose)
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://famlin:famlin@famlin-db:5432/famlin?schema=public
JWT_SECRET=change-this-to-a-secure-random-string-with-at-least-32-characters
# Primary client ID (used by the app and backend for token verification)
GOOGLE_CLIENT_ID=your-ios-or-android-oauth-client-id.apps.googleusercontent.com
# Optional: comma-separated list of additional client IDs (e.g. separate iOS and Android IDs)
GOOGLE_CLIENT_IDS=
ALLOWED_EMAILS=you@example.com,family@example.com

# Optional: Immich integration
IMMICH_BASE_URL=
IMMICH_API_KEY=

# Optional: Email notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Mobile (only needed for local / Docker Expo preview)
EXPO_PUBLIC_API_URL=http://localhost:3000
# Use the iOS or Android OAuth client ID from Google Cloud Console, NOT the Web client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-ios-or-android-oauth-client-id.apps.googleusercontent.com
