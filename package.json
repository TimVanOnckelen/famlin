{
  "name": "famlin",
  "version": "0.3.2",
  "private": false,
  "description": "Private, self-hosted family updates app",
  "license": "MIT",
  "author": "Tim Van Onckelen",
  "keywords": [
    "family",
    "social",
    "self-hosted",
    "expo",
    "react-native",
    "fastify",
    "prisma"
  ],
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "test:backend": "cd backend && npm test",
    "dev:admin": "cd backend/admin && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "dev:docs": "cd docs && npm start",
    "dev:web": "npm run dev --workspace=web",
    "build:admin": "cd backend/admin && npm run build",
    "build:docs": "cd docs && npm run build",
    "build:web": "npm run build --workspace=web",
    "watch:web": "npm run watch --workspace=web",
    "build:api-client": "npm run build --workspace=packages/api-client",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "lint:backend": "cd backend && npm run lint",
    "lint:admin": "cd backend/admin && npm run lint",
    "lint:web": "npm run lint --workspace=web",
    "lint:api-client": "npm run lint --workspace=packages/api-client",
    "lint:mobile": "cd mobile && npm run lint",
    "lint": "npm run lint:backend && npm run lint:admin && npm run lint:web && npm run lint:api-client && npm run lint:mobile"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.46.0"
  }
}
